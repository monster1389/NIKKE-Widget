<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <title><%= name %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { width: 100%; height: 100%; overflow: hidden; background: transparent; }
    #container { width: 100%; height: 100%; }
  </style>
</head>
<body>
  <div id="container"></div>

  <script src="/public/spine-player/spine-player.js"></script>
  <script>
    (function() {
      var container = document.getElementById('container');
      var defaultAnim = '<%- defaultAnim %>';
      var loop = <%= loop %>;
      var touchAnimName = '<%- touchAnim %>';
      var animations = [];
      var currentIdleAnim = defaultAnim;
      var actionPlaying = false;
      var player;

      function sendParent(data) {
        window.parent.postMessage(data, '*');
      }

      player = new spine.SpinePlayer(container, {
        binaryUrl: '<%- skel %>',
        atlasUrl: '<%- atlas %>',
        animation: defaultAnim || undefined,
        alpha: true,
        backgroundColor: '#00000000',
        premultipliedAlpha: true,
        showControls: false,
        showLoading: false,
        viewport: { transitionTime: 0 },
        success: function(p) {
          animations = p.skeleton.data.animations.map(function(a) { return a.name; });
          console.log('Available animations:', animations);
          if (!currentIdleAnim) {
            currentIdleAnim = animations[0] || '';
          }

          var frozenViewport = null;

          function computeUnionBounds() {
            var skeleton = p.skeleton;
            var minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
            animations.forEach(function(name) {
              var anim = skeleton.data.animations.find(function(a) { return a.name === name; });
              if (!anim) return;
              var steps = Math.max(2, Math.min(10, Math.floor(anim.duration * 4)));
              for (var i = 0; i <= steps; i++) {
                skeleton.setToSetupPose();
                anim.apply(skeleton, (i / steps) * anim.duration, (i / steps) * anim.duration, false, null, 1, spine.MixBlend.setup, spine.MixDirection.mix);
                skeleton.updateWorldTransform();
                var b = skeleton.getBoundsRect();
                if (!b || b.width === 0 || b.height === 0) return;
                minX = Math.min(minX, b.x);
                minY = Math.min(minY, b.y);
                maxX = Math.max(maxX, b.x + b.width);
                maxY = Math.max(maxY, b.y + b.height);
              }
            });
            skeleton.setToSetupPose();
            skeleton.updateWorldTransform();

            var boundsWidth = maxX - minX;
            var boundsHeight = maxY - minY;
            var cx = (minX + maxX) / 2;
            var cy = (minY + maxY) / 2;
            var size = Math.max(boundsWidth, boundsHeight) * 1.2;

            return {
              x: cx - size / 2,
              y: cy - size / 2,
              width: size,
              height: size
            };
          }

          frozenViewport = computeUnionBounds();

          p.calculateAnimationViewport = function(anim, vp) {
            if (frozenViewport) {
              vp.x = frozenViewport.x;
              vp.y = frozenViewport.y;
              vp.width = frozenViewport.width;
              vp.height = frozenViewport.height;
            }
          };

          p.setAnimation(currentIdleAnim, loop);
          p.play();
          sendParent({ type: 'ready', animations: animations });

          p.animationState.addListener({
            complete: function(entry) {
              if (!entry.loop) {
                actionPlaying = false;
                player.setAnimation(currentIdleAnim, true);
                sendParent({ type: 'ended', animation: entry.animation.name });
              }
            }
          });

          p.canvas.addEventListener('click', function() {
            if (actionPlaying) return;
            var hasAnim = animations.indexOf(touchAnimName) >= 0;
            if (!hasAnim) return;
            actionPlaying = true;
            player.setAnimation(touchAnimName, false);
            sendParent({ type: 'playing', animation: touchAnimName });
          });
        },
        error: function(p, msg) {
          console.error('Spine load error:', msg);
        },
      });

      window.addEventListener('message', function(e) {
        var data = e.data || {};
        switch (data.action) {
          case 'play':
            if (!data.animation || animations.indexOf(data.animation) < 0) return;
            if (data.loop === false && actionPlaying) return;
            if (data.loop === false) actionPlaying = true;
            player.setAnimation(data.animation, data.loop !== false);
            break;
          case 'setIdle':
            if (!data.animation || animations.indexOf(data.animation) < 0) return;
            currentIdleAnim = data.animation;
            break;
          case 'getAnimations':
            sendParent({ type: 'animations', animations: animations });
            break;
        }
      });
    })();
  </script>
</body>
</html>
