<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= name %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body, #container, .spine-player, .spine-player-canvas {
      width: 100%; height: 100%; overflow: hidden;
      background: transparent;
    }
    .back-btn {
      position: fixed;
      top: 16px;
      left: 16px;
      z-index: 10;
      padding: 8px 16px;
      background: rgba(0,0,0,0.5);
      color: #ccc;
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 6px;
      text-decoration: none;
      font-size: 14px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      transition: background 0.2s, color 0.2s;
    }
    .back-btn:hover { background: rgba(0,0,0,0.7); color: #fff; }

    /* Skin arrows */
    .skin-arrow {
      position: fixed;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
      width: 40px;
      height: 60px;
      background: rgba(0,0,0,0.3);
      color: rgba(255,255,255,0.6);
      border: none;
      border-radius: 4px;
      font-size: 24px;
      cursor: pointer;
      text-decoration: none;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s, color 0.2s;
    }
    .skin-arrow:hover { background: rgba(0,0,0,0.6); color: #fff; }
    .skin-arrow-left { left: 8px; }
    .skin-arrow-right { right: 8px; }
    .skin-indicator {
      position: fixed;
      bottom: 96px;
      right: 16px;
      z-index: 10;
      font-size: 12px;
      color: rgba(255,255,255,0.5);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    /* Skin bar */
    .skin-bar-wrap {
      position: fixed;
      top: 16px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      background: rgba(0,0,0,0.4);
      border-radius: 20px;
      padding: 4px 10px;
      max-width: 60vw;
    }
    .skin-bar {
      display: flex;
      gap: 5px;
      overflow-x: auto;
      scrollbar-width: none;
      user-select: none;
    }
    .skin-bar::-webkit-scrollbar { display: none; }
    .skin-chip {
      flex-shrink: 0;
      padding: 3px 12px;
      background: rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.65);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 12px;
      font-size: 12px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s, color 0.2s;
    }
    .skin-chip:hover { background: rgba(255,255,255,0.18); color: rgba(255,255,255,0.9); }
    .skin-chip.active { background: rgba(255,255,255,0.22); color: #fff; border-color: rgba(255,255,255,0.4); }

    /* Animation bar */
    .anim-bar-wrap {
      position: fixed;
      bottom: 16px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      display: flex;
      align-items: center;
      gap: 4px;
      background: rgba(0,0,0,0.4);
      border-radius: 20px;
      padding: 6px 12px;
      max-width: 50vw;
    }
    .anim-toggle-btn {
      flex-shrink: 0;
      width: 24px; height: 24px;
      padding: 0;
      background: rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.7);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 50%;
      font-size: 14px;
      line-height: 22px;
      text-align: center;
      cursor: pointer;
    }
    .anim-toggle-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }
    .anim-bar {
      display: flex;
      gap: 6px;
      overflow-x: auto;
      scrollbar-width: none;
      cursor: grab;
      user-select: none;
    }
    .anim-bar::-webkit-scrollbar { display: none; }
    .anim-bar:active { cursor: grabbing; }
    .anim-chip {
      flex-shrink: 0;
      padding: 4px 14px;
      background: rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.8);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 14px;
      font-size: 13px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
    }
    .anim-chip:hover { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.4); }
  </style>
</head>
<body>
  <div id="container"
       data-skels="<%= skel %>"
       data-atlas="<%= atlas %>"
       data-animation="<%= defaultAnim %>"
       data-loop="<%= loop %>"
       data-touch="<%= touchAnim %>"
       data-viewport="padded"
       data-world-height="2400">
  </div>

  <% if (!hideBack) { %>
  <a class="back-btn" href="/">← 返回</a>
  <% } %>

  <a class="skin-arrow skin-arrow-left" href="/<%= prevChar %>" title="上一个角色">&lt;</a>
  <a class="skin-arrow skin-arrow-right" href="/<%= nextChar %>" title="下一个角色">&gt;</a>
  <div class="skin-indicator" id="skin-indicator"></div>

  <div class="skin-bar-wrap" id="skin-bar-wrap" style="display:none">
    <div class="skin-bar" id="skin-bar"></div>
  </div>

  <div class="anim-bar-wrap">
    <button class="anim-toggle-btn">&lt;</button>
    <div class="anim-bar" id="anim-bar"></div>
  </div>

  <script src="/public/spine-player/spine-player.js"></script>
  <script src="/public/js/player-core.js"></script>
  <script>
    var allChars = <%- JSON.stringify(allChars) %>;
    var currentIndex = <%- currentIndex %>;

    // Show character position indicator
    document.getElementById('skin-indicator').textContent = (currentIndex + 1) + ' / ' + allChars.length;

    window.Live2DPlayer.on('onReady', function(p, animations, skinNames) {
      // Build skin bar (if more than 1 skin)
      if (skinNames.length > 1) {
        var skinBar = document.getElementById('skin-bar');
        var curSkin = window.Live2DPlayer.getCurrentSkin();
        skinNames.forEach(function(name, i) {
          var chip = document.createElement('span');
          chip.className = 'skin-chip' + (i === curSkin ? ' active' : '');
          chip.textContent = name;
          chip.addEventListener('click', function() {
            window.Live2DPlayer.switchSkin(i);
          });
          skinBar.appendChild(chip);
        });
        document.getElementById('skin-bar-wrap').style.display = '';
        updateSkinIndicator();
      }

      // Build animation bar
      var bar = document.getElementById('anim-bar');
      animations.forEach(function(name) {
        var chip = document.createElement('span');
        chip.className = 'anim-chip';
        chip.textContent = name;
        chip.addEventListener('click', function() {
          window.Live2DPlayer.playAnimation(name, false);
        });
        bar.appendChild(chip);
      });
    });

    function updateSkinIndicator() {
      var idx = window.Live2DPlayer.getCurrentSkin();
      var total = window.Live2DPlayer.getSkinCount();
      var chips = document.querySelectorAll('.skin-chip');
      chips.forEach(function(c, i) { c.classList.toggle('active', i === idx); });
      var indicator = document.getElementById('skin-indicator');
      var charInfo = (currentIndex + 1) + ' / ' + allChars.length;
      indicator.textContent = total > 1 ? '角色 ' + charInfo + ' · 皮肤 ' + (idx + 1) + '/' + total : '角色 ' + charInfo;
    }

    window.Live2DPlayer.on('onSkinChange', function() { updateSkinIndicator(); });

    // Drag to switch character (anywhere on page except anim bar), wraps around
    (function() {
      var dragStart = 0;
      var threshold = 60;
      var tracking = false;
      var len = allChars.length;

      function onStart(x) {
        dragStart = x;
        tracking = true;
      }
      function onEnd(x) {
        if (!tracking) return;
        tracking = false;
        var dx = x - dragStart;
        if (Math.abs(dx) >= threshold) {
          if (dx > 0) {
            window.location.href = '/' + allChars[(currentIndex - 1 + len) % len];
          } else {
            window.location.href = '/' + allChars[(currentIndex + 1) % len];
          }
        }
      }

      document.addEventListener('mousedown', function(e) {
        if (e.target.closest('#anim-bar')) return;
        onStart(e.clientX);
      });
      document.addEventListener('mouseup', function(e) {
        onEnd(e.clientX);
      });
      document.addEventListener('touchstart', function(e) {
        if (e.target.closest('#anim-bar')) return;
        onStart(e.touches[0].clientX);
      });
      document.addEventListener('touchend', function(e) {
        onEnd(e.changedTouches[0].clientX);
      });
    })();

    // Animation bar: toggle collapse/expand
    (function() {
      var bar = document.getElementById('anim-bar');
      var btn = document.querySelector('.anim-toggle-btn');
      btn.addEventListener('click', function() {
        var hidden = bar.style.display === 'none';
        bar.style.display = hidden ? '' : 'none';
        btn.textContent = hidden ? '<' : '>';
      });
    })();

    // Animation bar: mouse wheel horizontal scroll + drag scroll
    (function() {
      var bar = document.getElementById('anim-bar');
      bar.addEventListener('wheel', function(e) {
        e.preventDefault();
        bar.scrollLeft += e.deltaY;
      });

      var isDown = false, startX, scrollLeft;
      bar.addEventListener('mousedown', function(e) {
        isDown = true;
        startX = e.pageX;
        scrollLeft = bar.scrollLeft;
        e.preventDefault();
      });
      document.addEventListener('mousemove', function(e) {
        if (!isDown) return;
        var dx = e.pageX - startX;
        bar.scrollLeft = scrollLeft - dx;
      });
      document.addEventListener('mouseup', function() { isDown = false; });
    })();
  </script>
</body>
</html>
