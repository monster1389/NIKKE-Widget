<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <title><%= name %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { width: 100%; height: 100%; overflow: hidden; background: transparent; }
    #container { width: 100%; height: 100%; }
  </style>
</head>
<body>
  <div id="container"></div>

  <script src="/public/spine-player/spine-player.js"></script>
  <script>
    (function() {
      var container = document.getElementById('container');
      var defaultAnim = '<%- defaultAnim %>';
      var loop = <%= loop %>;
      var touchAnimName = '<%- touchAnim %>';
      var animations = [];
      var currentIdleAnim = defaultAnim;
      var player;

      function sendParent(data) {
        window.parent.postMessage(data, '*');
      }

      player = new spine.SpinePlayer(container, {
        binaryUrl: '<%- skel %>',
        atlasUrl: '<%- atlas %>',
        animation: defaultAnim || undefined,
        alpha: true,
        backgroundColor: '#00000000',
        premultipliedAlpha: true,
        showControls: false,
        showLoading: false,
        viewport: { transitionTime: 0 },
        success: function(p) {
          animations = p.skeleton.data.animations.map(function(a) { return a.name; });
          console.log('Available animations:', animations);
          if (!currentIdleAnim) {
            currentIdleAnim = animations[0] || '';
          }
          p.setAnimation(currentIdleAnim, loop);
          p.play();
          sendParent({ type: 'ready', animations: animations });

          var frozenViewport = null;

          function freezeViewport() {
            if (!frozenViewport && p.currentViewport && p.currentViewport.width) {
              frozenViewport = {
                x: p.currentViewport.x,
                y: p.currentViewport.y,
                width: p.currentViewport.width,
                height: p.currentViewport.height,
              };
            }
            if (frozenViewport && p.currentViewport) {
              p.currentViewport.x = frozenViewport.x;
              p.currentViewport.y = frozenViewport.y;
              p.currentViewport.width = frozenViewport.width;
              p.currentViewport.height = frozenViewport.height;
              p.previousViewport.x = frozenViewport.x;
              p.previousViewport.y = frozenViewport.y;
              p.previousViewport.width = frozenViewport.width;
              p.previousViewport.height = frozenViewport.height;
            }
          }

          var origSetAnimation = p.setAnimation.bind(p);
          p.setAnimation = function(name, loop) {
            var result = origSetAnimation(name, loop);
            freezeViewport();
            return result;
          };

          p.animationState.addListener({
            complete: function(entry) {
              if (!entry.loop) {
                player.setAnimation(currentIdleAnim, true);
                sendParent({ type: 'ended', animation: entry.animation.name });
              }
            }
          });

          p.canvas.addEventListener('click', function() {
            var hasAnim = animations.indexOf(touchAnimName) >= 0;
            if (!hasAnim) return;
            player.setAnimation(touchAnimName, false);
            sendParent({ type: 'playing', animation: touchAnimName });
          });
        },
        error: function(p, msg) {
          console.error('Spine load error:', msg);
        },
      });

      window.addEventListener('message', function(e) {
        var data = e.data || {};
        switch (data.action) {
          case 'play':
            if (!data.animation || animations.indexOf(data.animation) < 0) return;
            player.setAnimation(data.animation, data.loop !== false);
            break;
          case 'setIdle':
            if (!data.animation || animations.indexOf(data.animation) < 0) return;
            currentIdleAnim = data.animation;
            break;
          case 'getAnimations':
            sendParent({ type: 'animations', animations: animations });
            break;
        }
      });
    })();
  </script>
</body>
</html>
