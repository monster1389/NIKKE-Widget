<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <title>Live2D Characters</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #1a1a2e;
      color: #eee;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 48px 24px;
      min-height: 100vh;
    }
    h1 { font-size: 24px; margin-bottom: 32px; color: #e0e0e0; }
    .grid {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      justify-content: center;
    }
    .card {
      display: block;
      padding: 20px 40px;
      background: #16213e;
      border: 1px solid #0f3460;
      border-radius: 8px;
      color: #e94560;
      text-decoration: none;
      font-size: 18px;
      transition: background 0.2s, border-color 0.2s;
    }
    .card:hover { background: #1a2a4e; border-color: #e94560; }
  </style>
</head>
<body>
  <h1>Live2D 角色列表</h1>
  <div class="grid">
    <% characters.forEach(function(c) { %>
      <a class="card" href="/<%= c %>"><%= c %></a>
    <% }); %>
  </div>
</body>
</html>
