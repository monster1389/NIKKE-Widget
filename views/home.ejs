<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <title>Live2D Characters</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #1a1a2e;
      color: #eee;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 48px 24px;
      min-height: 100vh;
    }
    h1 { font-size: 24px; margin-bottom: 32px; color: #e0e0e0; }
    .grid {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      justify-content: center;
    }
    .card {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding: 16px;
      background: #16213e;
      border: 1px solid #0f3460;
      border-radius: 8px;
      color: #e94560;
      text-decoration: none;
      font-size: 18px;
      transition: background 0.2s, border-color 0.2s;
      width: 200px;
    }
    .card:hover { background: #1a2a4e; border-color: #e94560; }
    .card img {
      width: 168px;
      height: 168px;
      object-fit: contain;
      border-radius: 4px;
      background: rgba(0,0,0,0.3);
    }
    .card .no-preview {
      width: 168px;
      height: 168px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 4px;
      background: rgba(0,0,0,0.3);
      font-size: 14px;
      color: #666;
    }
  </style>
</head>
<body>
  <h1>Live2D 角色列表</h1>
  <div class="grid">
    <% characters.forEach(function(c) { %>
      <a class="card" href="/<%= c.name %>">
        <% if (c.preview) { %>
          <img src="<%= c.preview %>" alt="<%= c.name %>">
        <% } else { %>
          <div class="no-preview">no preview</div>
        <% } %>
        <span><%= c.name %></span>
      </a>
    <% }); %>
  </div>
</body>
</html>
